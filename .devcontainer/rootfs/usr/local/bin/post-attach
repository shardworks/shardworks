#!/usr/bin/env bash
set -euo pipefail

LOG_DIR="/workspace/.devcontainer/logs"
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/post-attach.log") 2>&1

for script in /usr/local/bin/post-attach.d/*.sh; do
    [ -f "$script" ] || continue
    echo "[post-attach] Running $(basename "$script")..." >&2
    bash "$script"
done
